# =============================================================================
# AI Procurement OS — Environment Configuration
# Copy this file to .env and fill in your values:
#   copy .env.example .env
# =============================================================================

# --- Automation (production default: fully automated) ---
AUTO_APPROVE=true
EMAIL_DRY_RUN=true

# --- LLM (default: local Ollama — no API key needed) ---
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434

# Optional cloud LLM fallback (uncomment one):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Email (required for live outreach/proposal sends) ---
# Leave SMTP_* unset to keep dry-run mode (emails logged, not sent).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@agency.com
# SMTP_PASS=your-app-password
# SMTP_FROM=you@agency.com
# EMAIL_DRY_RUN=false

# Alternative email providers:
# SENDGRID_API_KEY=
# RESEND_API_KEY=

# --- Dashboard server ---
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8765

# --- SaaS / payments (optional — for future billing) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PORTAL_SIGNING_SECRET=

# --- Agency overrides (optional — defaults in brain/config.yaml) ---
# AGENCY_NAME=Your Sourcing Agency
# AGENCY_MARGIN_PERCENT=15
