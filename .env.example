# =============================================================================
# AI Procurement OS — Environment Configuration
# Copy this file to .env and fill in your values:
#   copy .env.example .env
# =============================================================================

# --- Automation (production default: fully automated) ---
AUTO_APPROVE=true
EMAIL_DRY_RUN=true

# --- LLM (default: local Ollama — no API key needed) ---
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434

# Optional cloud LLM fallback (uncomment one):
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# --- Contact & notifications ---
CONTACT_EMAIL=aarfa.developers@gmail.com
NOTIFY_EMAIL=aarfa.developers@gmail.com

# --- Email (required for live outreach/proposal sends + form alerts) ---
# Gmail: use an App Password (not your regular password).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=aarfa.developers@gmail.com
# SMTP_PASS=your-gmail-app-password
# SMTP_FROM=aarfa.developers@gmail.com
# EMAIL_DRY_RUN=false

# Alternative: Resend (https://resend.com) — no SMTP needed
# RESEND_API_KEY=re_...
# RESEND_FROM=AI Procurement OS <onboarding@resend.dev>

# --- Dashboard server ---
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8765

# --- SaaS / payments (optional — for future billing) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PORTAL_SIGNING_SECRET=

# --- Agency overrides (optional — defaults in brain/config.yaml) ---
# AGENCY_NAME=Your Sourcing Agency
# AGENCY_MARGIN_PERCENT=15
